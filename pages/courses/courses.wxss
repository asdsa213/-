.course-card {
  display: block;
  position: relative;
  overflow: hidden;
}

.course-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  width: 10rpx;
  height: 100%;
  background: #1f7a5c;
}

.notice-text {
  margin-top: 20rpx;
  padding: 18rpx 22rpx;
  border-radius: 12rpx;
  background: #fff7ed;
  color: #c05621;
  font-size: 26rpx;
  line-height: 1.5;
}

.class-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 22rpx;
  padding: 20rpx 24rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #dceee7;
}

.switch-label {
  color: #7a8491;
  font-size: 24rpx;
}

.switch-name {
  margin-top: 6rpx;
  color: #1f2933;
  font-size: 30rpx;
  font-weight: 700;
}

.switch-button {
  flex-shrink: 0;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #e8f5ef;
  color: #1f7a5c;
  font-size: 26rpx;
  font-weight: 600;
}

.course-name {
  color: #1f2933;
  font-size: 34rpx;
  font-weight: 800;
  padding-left: 14rpx;
}

.teacher,
.recent,
.count {
  margin-top: 12rpx;
  color: #62707e;
  font-size: 28rpx;
  line-height: 1.6;
  padding-left: 14rpx;
}

.recent {
  color: #374151;
}

.count {
  display: inline-block;
  margin-top: 18rpx;
  margin-left: 14rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef6ff;
  color: #2563eb;
  font-size: 24rpx;
}
