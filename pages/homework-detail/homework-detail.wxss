.detail-card {
  line-height: 1.7;
  border-top: 8rpx solid #1f7a5c;
}

.info-line {
  color: #6b7280;
  font-size: 28rpx;
}

.deadline {
  margin-top: 8rpx;
  color: #d97706;
}

.status-line {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 28rpx;
}

.status-text {
  display: inline-block;
  margin-left: 8rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.status-normal {
  background: #e8f5ef;
  color: #1f7a5c;
}

.status-urgent {
  background: #fff1e6;
  color: #c05621;
}

.status-ended {
  background: #eef2f7;
  color: #6b7280;
}

.section-title {
  margin-top: 28rpx;
  color: #152238;
  font-size: 30rpx;
  font-weight: 700;
}

.content {
  margin-top: 10rpx;
  color: #374151;
  font-size: 28rpx;
  line-height: 1.7;
}

.know-button {
  margin-top: 36rpx;
  border-radius: 16rpx;
  background: #1f7a5c;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 24rpx rgba(31, 122, 92, 0.18);
}

.know-button::after {
  border: 0;
}

.edit-button {
  margin-top: 22rpx;
  border-radius: 16rpx;
  background: #ffffff;
  color: #1f7a5c;
  font-size: 30rpx;
  font-weight: 600;
  border: 1rpx solid #b8ded1;
}

.edit-button::after {
  border: 0;
}

.delete-button {
  margin-top: 22rpx;
  border-radius: 16rpx;
  background: #ffffff;
  color: #d93025;
  font-size: 30rpx;
  font-weight: 600;
  border: 1rpx solid #f2c6c3;
}

.delete-button::after {
  border: 0;
}
