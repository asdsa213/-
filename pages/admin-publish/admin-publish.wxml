<view class="page">
  <view class="page-title">{{pageTitle}}</view>

  <view class="card form-card">
    <view class="form-item">
      <view class="label">选择班级</view>
      <picker range="{{classes}}" range-key="name" value="{{classIndex}}" bindchange="onClassChange">
        <view class="picker-box">{{selectedClass.name}}</view>
      </picker>
    </view>

    <view class="form-item">
      <view class="label">选择课程</view>
      <picker range="{{courses}}" range-key="name" value="{{courseIndex}}" bindchange="onCourseChange">
        <view class="picker-box">{{selectedCourse.name}}</view>
      </picker>
    </view>

    <view class="form-item">
      <view class="label">作业标题</view>
      <input class="input" placeholder="例如：E-R 图练习补充作业" value="{{title}}" bindinput="onTitleInput" />
    </view>

    <view class="form-item">
      <view class="label">完整作业内容</view>
      <textarea class="textarea" placeholder="请输入完整作业要求" value="{{requirement}}" bindinput="onRequirementInput" />
    </view>

    <view class="form-item">
      <view class="label">截止时间</view>
      <view class="deadline-row">
        <picker mode="date" value="{{deadlineDate}}" bindchange="onDeadlineDateChange">
          <view class="picker-box deadline-picker">{{deadlineDate}}</view>
        </picker>
        <picker mode="time" value="{{deadlineTime}}" bindchange="onDeadlineTimeChange">
          <view class="picker-box deadline-picker">{{deadlineTime}}</view>
        </picker>
      </view>
      <view class="help-text">保存时会自动生成：{{deadlineDate}} {{deadlineTime}}</view>
    </view>

    <view class="form-item">
      <view class="label">备注</view>
      <input class="input" placeholder="例如：下节课前完成" value="{{note}}" bindinput="onNoteInput" />
    </view>
  </view>

  <button class="save-button" bindtap="saveHomework">{{saveButtonText}}</button>
</view>
