.form-card {
  padding-top: 8rpx;
}

.form-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #edf1f5;
}

.form-item:last-child {
  border-bottom: 0;
}

.label {
  margin-bottom: 14rpx;
  color: #374151;
  font-size: 28rpx;
  font-weight: 600;
}

.picker-box,
.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 12rpx;
  background: #f5f7fa;
  color: #1f2933;
  font-size: 28rpx;
}

.picker-box,
.input {
  min-height: 84rpx;
  padding: 20rpx 22rpx;
}

.textarea {
  height: 220rpx;
  padding: 20rpx 22rpx;
  line-height: 1.6;
}

.deadline-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.deadline-picker {
  text-align: center;
}

.help-text {
  margin-top: 12rpx;
  color: #8a94a3;
  font-size: 24rpx;
}

.save-button {
  margin-top: 36rpx;
  border-radius: 16rpx;
  background: #1f7a5c;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 24rpx rgba(31, 122, 92, 0.18);
}

.save-button::after {
  border: 0;
}
