.form-card {
  padding-top: 8rpx;
}

.form-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #edf1f5;
}

.form-item:last-child {
  border-bottom: 0;
}

.label {
  margin-bottom: 14rpx;
  color: #374151;
  font-size: 28rpx;
  font-weight: 600;
}

.input {
  width: 100%;
  min-height: 84rpx;
  box-sizing: border-box;
  padding: 20rpx 22rpx;
  border-radius: 12rpx;
  background: #f5f7fa;
  color: #1f2933;
  font-size: 28rpx;
}

.save-button {
  margin-top: 36rpx;
  border-radius: 16rpx;
  background: #1f7a5c;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 24rpx rgba(31, 122, 92, 0.18);
}

.save-button::after {
  border: 0;
}

.list-card {
  margin-top: 34rpx;
}

.section-title {
  margin-bottom: 18rpx;
  color: #152238;
  font-size: 32rpx;
  font-weight: 700;
}

.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #edf1f5;
}

.list-item:last-child {
  border-bottom: 0;
}

.item-title {
  color: #1f2933;
  font-size: 30rpx;
  font-weight: 600;
}

.item-meta {
  margin-top: 8rpx;
  color: #7a8491;
  font-size: 24rpx;
}

.small-delete-button {
  flex-shrink: 0;
  width: 132rpx;
  margin: 0;
  border-radius: 12rpx;
  background: #fff5f5;
  color: #d93025;
  font-size: 26rpx;
  line-height: 64rpx;
}

.small-delete-button::after {
  border: 0;
}

.empty-line {
  padding: 20rpx 0;
  color: #8a94a3;
  font-size: 28rpx;
}
