<view class="page">
  <view class="page-title">我的班级</view>
  <view class="page-subtitle">当前绑定班级的基础信息</view>
  <picker wx:if="{{classes.length > 1}}" range="{{classes}}" range-key="name" value="{{classIndex}}" bindchange="onClassChange">
    <view class="class-switch">
      <view>
        <view class="switch-label">当前班级</view>
        <view class="switch-name">{{student.className}}</view>
      </view>
      <view class="switch-button">切换班级</view>
    </view>
  </picker>

  <view wx:if="{{loadError}}" class="notice-text">{{loadError}}</view>

  <view class="card">
    <view class="info-row">班级：{{student.className}}</view>
    <view class="info-row">姓名：{{student.name}}</view>
    <view class="info-row">学号：{{student.studentNo}}</view>
  </view>

  <button class="leave-button" bindtap="leaveCurrentClass">退出当前班级</button>

  <view class="card stat-card">
    <view class="stat-item">
      <view class="stat-number">{{courseCount}}</view>
      <view class="stat-label">当前课程</view>
    </view>
    <view class="stat-item">
      <view class="stat-number">{{homeworkCount}}</view>
      <view class="stat-label">班级作业</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">课程列表</view>
    <block wx:if="{{courses.length > 0}}">
      <view class="course-line" wx:for="{{courses}}" wx:key="id">
        <text>{{item.name}}</text>
        <text class="teacher">{{item.teacher}}</text>
      </view>
    </block>
    <view wx:else class="small-empty">暂无课程</view>
  </view>

  <view wx:if="{{canViewMembers}}" class="card">
    <view class="section-title">班级成员</view>
    <block wx:if="{{members.length > 0}}">
      <view class="member-line" wx:for="{{members}}" wx:key="studentNo">
        <text>{{item.name}}</text>
        <text class="teacher">{{item.studentNo}}</text>
      </view>
    </block>
    <view wx:else class="small-empty">暂无成员</view>
  </view>
</view>
